<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive-icon BACKGROUND layer.
     Per Android adaptive-icon spec the background is a flat layer (no glyph,
     no text). Filling the full 108×108dp viewport with the brand bg color
     means circular / squircle / square / teardrop launcher masks all yield
     a clean teal-dark plate behind the foreground glyph. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:fillColor="#0C1618"
        android:pathData="M0,0h108v108H0z" />
</vector>
