<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive-icon FOREGROUND layer.
     Centered shield glyph drawn in AH brand accent (#2DD4C2). Stays inside
     the 66dp safe zone (coords 21..87) so circular / squircle launcher masks
     never crop it. Canvas outside the glyph is transparent so the launcher
     composites it over the background layer (or a themed bg for Material You).

     Glyph: filled heater-shield + a bg-color "drop" chevron and a small
     sink-hole disc below — the "and-hole" pun: queries fall into the hole.
     Specifically NOT concentric arcs (which read as Tor Browser's onion). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Filled brand-accent heater shield (bbox 30..78 x 30..84). -->
    <path
        android:fillColor="#2DD4C2"
        android:pathData="M30,30 H78 V54 C78,68 70,78 54,84 C38,78 30,68 30,54 Z" />

    <!-- Drop chevron (queries entering): bg-color stroke, rounded caps. -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#0C1618"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M43,47 L54,58 L65,47" />

    <!-- Sink hole below chevron (the literal "hole" in and-hole). -->
    <path
        android:fillColor="#0C1618"
        android:pathData="M54,70 m-4.5,0 a4.5,4.5 0,1 0,9 0 a4.5,4.5 0,1 0,-9 0 z" />
</vector>
